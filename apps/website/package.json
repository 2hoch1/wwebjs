{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@wwebjs/website",
  "version": "0.0.0",
  "private": true,
  "description": "wwebjs website",
  "type": "module",
  "scripts": {
    "build": "next build",
    "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
    "dev": "next dev",
    "format": "prettier --write '**/*.{ts,tsx,js,jsx,md,mdx,json,css}'",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "start": "next start",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "next": "^16.0.1",
    "nextra": "^4.6.0",
    "nextra-theme-docs": "^4.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shiki": "^3.15.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "pagefind": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
